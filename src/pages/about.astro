---
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { url } from "../utils/url-utils";
---
<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
        <div class="card-base z-10 relative w-full overflow-hidden">

            <!-- 배너 이미지 + About Me 오버레이 -->
            <div class="px-6 pt-6">
                <div class="relative w-full h-72 md:h-96 overflow-hidden rounded-xl">
                    <img
                        src={url('/about-banner.png')}
                        alt="banner"
                        class="w-full h-full object-cover object-center"
                    />
                    <!-- 하단 그라디언트 -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                    <!-- About Me 텍스트 -->
                    <div class="absolute bottom-6 left-7">
                        <p class="text-4xl md:text-5xl font-bold text-white tracking-widest drop-shadow-lg">About Me</p>
                    </div>
                </div>
            </div>

            <!-- 본문 -->
            <div class="flex flex-col items-start py-12 px-10 gap-3">

                <!-- 이름 + 한자 -->
                <div class="flex items-baseline gap-3">
                    <h1 class="text-4xl font-bold tracking-widest dark:text-neutral-50 transition">
                        이준한
                    </h1>
                    <span class="text-xl text-neutral-400 tracking-wider transition">李埈漢</span>
                </div>

                <!-- 구분선 -->
                <div class="h-px w-16 bg-[var(--primary)] rounded-full my-1 transition"></div>

                <!-- 소속 -->
                <p class="text-base text-neutral-500 dark:text-neutral-400 transition">
                    고려대학교 컴퓨터학과 재학 중
                </p>

                <!-- 이메일 -->
                <p class="text-sm text-neutral-500 dark:text-neutral-400 transition">
                    이메일 : <a href="mailto:siloyuki@korea.ac.kr" class="text-[var(--primary)] hover:underline underline-offset-4 transition">siloyuki@korea.ac.kr</a>
                </p>

                <!-- 인스타그램 -->
                <p class="text-sm text-neutral-500 dark:text-neutral-400 transition">
                    Instagram : <a href="https://www.instagram.com/shuu4na/" target="_blank" class="text-[var(--primary)] hover:underline underline-offset-4 transition">@shuu4na</a>
                </p>

            </div>

        </div>
    </div>
</MainGridLayout>
